{{!
    @template local_wb_news/wb_news_slide

    Classes required for JS:
    * none

    Example context (json):
    {
        "headline": "Sample Headline",
        "description": "Sample description text.",
        "bgimage": "path/to/image.jpg",
        "headerimage": "path/to/headerimage.jpg",
        "imagecaption": "Sample image caption",
        "instanceid": "unique_id",
        "editmode": true,
        "lightmode": true,
        "cssclasses": "extra-class",
        "tags": ["tag1", "tag2"]
    }
}}

<div class="d-flex justify-content-between align-items-center wb_news_slide {{sortorder}}">
    <div class="left-panel{{#lightmode}} text-light{{/lightmode}}{{#cssclasses}} {{cssclasses}}{{/cssclasses}}">
        {{#tags}} <span class="badge badge-success">{{.}}</span>{{/tags}}
        {{#headline}}
            <h1>{{{headline}}}</h1>
        {{/headline}}
        {{{description}}}
        {{#btntext}}
        <a href="{{btnlink}}" class="btn btn-primary mt-4" {{#btnlinktarget}}target="{{.}}"{{/btnlinktarget}} {{#btnlinkrel}}rel="{{.}}"{{/btnlinkrel}}>{{btntext}}</a>
        {{/btntext}}
        {{^dontshowarrows}}
            <div class="row mt-4 justify-content-center">
            </div>
        {{/dontshowarrows}}
        {{#editmode}}
        {{> local_wb_news/editsinglenews}}
        {{/editmode}}
    </div>
    <div class="right-panel">
        <div class="image-container w-100">
                {{^dontshowarrows}}
        <a class="carousel-control-prev position-absolute d-flex align-items-center justify-content-center" href="#wb_news_carousel-{{instanceid}}" role="button" data-slide="prev" style="top: 50%; left: -1.3rem; transform: translateY(-55%); z-index: 10; width: 2.5rem; height: 2.5rem;">
            <span class="sr-only">{{#str}} previous, local_wb_news {{/str}}</span>
            <i class="fas fa-chevron-left" aria-hidden="true"></i>
        </a>
        <a class="carousel-control-next position-absolute d-flex align-items-center justify-content-center" href="#wb_news_carousel-{{instanceid}}" role="button" data-slide="next" style="top: 50%; right: -1.3rem; transform: translateY(-55%); z-index: 10; width: 2.5rem; height: 2.5rem;">
            <span class="sr-only">{{#str}} next, local_wb_news {{/str}}</span>
            <i class="fas fa-chevron-right" aria-hidden="true"></i>
        </a>
        {{/dontshowarrows}}
            <!-- Trigger for modal -->
            <a href="#" data-toggle="modal" data-target="#modal-image-{{sortorder}}">
                <img src="{{bgimage}}{{headerimage}}" class="img-fluid w-100" aria-label="{{bgimagetext}}{{headerimagetext}}">
            </a>
            {{#imagecaption}}
            <div class="image-caption">{{imagecaption}}</div>
            {{/imagecaption}}
        </div>
    </div>
</div>

