    {{!
        @template core_course/coursecard

        This template renders the a card for the course cards.

        Example context (json):
        {
            "courses": [
                {
                    "name": "Assignment due 1",
                    "viewurl": "https://moodlesite/course/view.php?id=2",
                    "courseimage": "https://moodlesite/pluginfile/123/course/overviewfiles/123.jpg",
                    "fullname": "course 3",
                    "hasprogress": true,
                    "progress": 10,
                    "visible": true
                }
            ]
        }
    }}
    <div class="card course-card mx-1 test" role="listitem"
        data-region="course-content"
        data-course-id="{{{id}}}">
        {{overviewfiles}}
        <a href="{{viewurl}}" tabindex="-1" style="background-image: url('{{courseimage}}')">
    <div class="card-banner" >
        <div class="overlay">
            <div class="text-block">
                <p class="course-date">{{startdate}}</p>
                <h2 class="course-title">{{shortname}}</h2>
            </div>
        </div>
    </div>
        </a>
    </div>


<script>
// Function to convert UNIX timestamp to readable date
function formatTimestamp(timestamp) {
    const date = new Date(timestamp * 1000);
    const options = { day: 'numeric', month: 'long', year: 'numeric' };
    return new Intl.DateTimeFormat('en-GB', options).format(date);
}

// Query all course cards
const courseCards = document.querySelectorAll('.card.course-card');

courseCards.forEach(card => {
    // Get the unique course ID
    const courseId = card.getAttribute('data-course-id');
    
    // Find the course-date element inside this card
    const courseDateElement = card.querySelector('.course-date');
    
    // Extract the timestamp from the text content
    const dateText = courseDateElement.textContent.trim();
    const parts = dateText.split(' ');
    
    if (parts.length > 0) {
        const timestamp = parseInt(parts[0], 10);
        if (!isNaN(timestamp)) {
            // Replace the timestamp with a formatted date
            const formattedDate = formatTimestamp(timestamp);
            courseDateElement.textContent = `${formattedDate}`;
        }
    }
});
</script>

